{
  "title": "TheirStack Company & Tech Stack Scraper",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "technologies": {
      "title": "Technologies",
      "type": "array",
      "description": "Technologies to search companies for.",
      "editor": "stringList",
      "items": {
        "type": "string"
      }
    },

    "country": {
      "title": "Country",
      "type": "string",
      "description": "Filter companies by country (optional)."
    },

    "industry": {
      "title": "Industry",
      "type": "string",
      "description": "Filter companies by industry (optional)."
    },

    "companySize": {
      "title": "Company Size",
      "type": "string",
      "description": "Filter by company size (optional). Example: 11-50, 51-200."
    },

    "maxResults": {
      "title": "Maximum Results",
      "type": "integer",
      "description": "Maximum number of companies per technology.",
      "default": 100
    }
  },

  "required": ["technologies"]
}
